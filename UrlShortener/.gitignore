## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/master/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leasePublic/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create the TestResults folder
#TestResults/

# ASYNC
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# External tool symbol cache
*.pdb

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored because of Package Restore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using tasks that place packages in without subdomain
#pakages/

# Microsoft Azure Build Output
csx/
*.Cache.cscfg
*.Cache.csdef

# Others
ClientBin/
~$*
*~
*.db
*.db-shm
*.db-wal
*.log
*.tmp
*.swp
*.bak
*.cache
*.out
*.pid
*.tmp.node
node_modules/
.DS_Store
.idea/
.vscode/
